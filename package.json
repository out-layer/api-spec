{
  "name": "@outlayer/api-spec",
  "version": "0.1.0-alpha.1",
  "description": "OpenAPI 3.1 specification for the OutLayer HTTP API",
  "license": "MIT",
  "private": true,
  "files": [
    "openapi.yaml",
    "openapi.json"
  ],
  "scripts": {
    "lint": "redocly lint openapi.yaml",
    "bundle": "redocly bundle openapi.yaml -o dist/openapi.json --ext json",
    "build": "redocly bundle openapi.yaml -o openapi.json --ext json",
    "check:bundle": "npm run build && git diff --exit-code openapi.json",
    "preview": "redocly preview-docs openapi.yaml",
    "types": "openapi-typescript openapi.yaml -o dist/types.ts"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "openapi-typescript": "^7.4.0"
  }
}
